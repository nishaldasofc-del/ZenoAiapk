<?xml version="1.0" encoding="utf-8"?>
<!--
    ZenoAi launcher foreground — uses the real brand logo PNG.
    The PNG assets (ic_launcher.png) in each mipmap-* folder are the primary icons.
    This foreground vector is used for adaptive icons (API 26+).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White background for the logo to sit on -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,14 A40,40 0 1,1 53.99,14 Z" />

</vector>
